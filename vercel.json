{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/adult-proxy.ts": {
      "runtime": "vercel-edge",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "ignoreCommand": "echo 'Convex _generated is auto-generated, ignoring in build'",
  "cleanUrls": true,
  "trailingSlash": false
}